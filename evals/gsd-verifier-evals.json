        "feedback_question": "验证完成，是否符合预期？"
      },
      "files": [],
      "expectations": [
        "执行功能验证",
        "使用 AskUserQuestion 收集反馈"
      ]
    },
    {
      "id": 2,
      "prompt": "gsd-verifier: 验证项目中所有测试是否通过",
      "expected_output": {
        "primary_output": "运行测试并验证结果",
        "test_summary": {
          "total": 50,
          "passed": 48,
          "failed": 2
