        "measurement_result": "实际测量值"
      },
      "files": [],
      "expectations": [
        "解析自定义验证标准",
        "执行测量",
        "与阈值比较"
      ]
    },
    {
      "id": 4,
      "prompt": "gsd-verifier: 验证 5 个功能点，其中 3 个通过，2 个失败",
      "expected_output": {
        "primary_output": "处理部分通过场景",
