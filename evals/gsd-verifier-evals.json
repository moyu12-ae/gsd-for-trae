        "failed_tests": ["test_login.py::test_invalid_credentials", "test_api.py::test_timeout"]
      },
      "files": [],
      "expectations": [
        "运行测试",
        "验证测试结果"
      ]
    },
    {
      "id": 3,
      "prompt": "gsd-verifier: 自定义验证标准：登录响应时间必须小于 200ms",
      "expected_output": {
        "primary_output": "根据自定义标准进行验证",
        "custom_criteria": {
          "metric": "响应时间",
          "threshold": "200ms",
          "comparison": "小于"
