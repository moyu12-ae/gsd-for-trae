      "prompt": "gsd-verifier: 验证功能时发现多个测试失败",
      "expected_output": {
        "primary_output": "分析验证失败原因",
        "failure_analysis": {
          "root_causes": ["数据库连接池配置错误", "API 超时设置过短"],
          "severity": "高"
